VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback

# Optional — custom event analytics via PostHog (https://posthog.com)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional — error monitoring via Sentry (https://sentry.io)
# VITE_SENTRY_DSN=
# VITE_APP_VERSION=

# Optional — Sentry source map uploads (CI / production builds only, never commit)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
