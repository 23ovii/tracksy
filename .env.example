VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback

# Optional — custom event analytics via PostHog (https://posthog.com)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.i.posthog.com   # EU only — vercel.json CSP blocks US

# Optional — Vercel Edge Config connection string for manual Spotify status banner
# EDGE_CONFIG=https://edge-config.vercel.com/ecfg_xxx?token=yyy
